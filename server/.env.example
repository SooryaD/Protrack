# ============================================
# ProTrack Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file
# ============================================

PORT=5000

# MySQL Database (Railway production values shown)
DB_HOST=nozomi.proxy.rlwy.net
DB_PORT=58035
DB_USER=root
DB_PASSWORD=your_railway_db_password
DB_NAME=railway
DB_SSL=true

# JWT — use a long random string (64+ chars) for production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Frontend URL for CORS — comma-separate multiple origins
# Example for production + local dev:
CLIENT_URL=https://protrack-delta.vercel.app,http://localhost:5173
